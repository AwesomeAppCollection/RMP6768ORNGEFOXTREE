# ==============================================================================
# OrangeFox / TWRP Unified fstab for Realme Pad (MT6768)
# ==============================================================================
/system         ext4    system       display="System";logical;first_stage_mount
/vendor         ext4    vendor       display="Vendor";logical;first_stage_mount
/product        ext4    product      display="Product";logical;first_stage_mount

# Standard Core Filesystems
/metadata       ext4    /dev/block/platform/bootdevice/by-name/md_udc      display="Metadata"
/data           ext4    /dev/block/platform/bootdevice/by-name/userdata    display="Data";fileencryption=aes-256-xts:aes-256-cts:v2+inlinecrypt_optimized,keymaster;encryptable=footer;length=-16384
/cache          ext4    /dev/block/platform/bootdevice/by-name/cache       display="Cache"

# Storage & Removable Devices (Fixed SD Card & OTG)
/external_sd    vfat    /dev/block/mmcblk1p1    /dev/block/mmcblk1         display="MicroSD Card";storage;wipeui;removable
/usb_otg        vfat    /dev/block/sdd1         /dev/block/sdd             display="USB-OTG";storage;wipeui;removable

# MediaTek Security & Calibration NV Layers
/mnt/vendor/protect_f    ext4    /dev/block/platform/bootdevice/by-name/protect1    display="Protect_F"
/mnt/vendor/protect_s    ext4    /dev/block/platform/bootdevice/by-name/protect2    display="Protect_S"
/mnt/vendor/nvdata       ext4    /dev/block/platform/bootdevice/by-name/nvdata      display="NVData"
/mnt/vendor/nvcfg        ext4    /dev/block/platform/bootdevice/by-name/nvcfg       display="NVCfg"
/mnt/vendor/persist      ext4    /dev/block/platform/bootdevice/by-name/persist     display="Persist"
/nvram                   emmc    /dev/block/platform/bootdevice/by-name/nvram       display="NVRam";backup=1

# Flashable Firmware Images & Critical Partition Blocks
/boot           emmc    /dev/block/platform/bootdevice/by-name/boot        display="Boot";backup=1;flashimg=1
/recovery       emmc    /dev/block/platform/bootdevice/by-name/recovery    display="Recovery";backup=1;flashimg=1
/dtbo           emmc    /dev/block/platform/bootdevice/by-name/dtbo        display="DTBO";backup=1;flashimg=1
/logo           emmc    /dev/block/platform/bootdevice/by-name/logo        display="Logo";backup=1;flashimg=1
/misc           emmc    /dev/block/platform/bootdevice/by-name/misc        display="Misc"
/persistent     emmc    /dev/block/platform/bootdevice/by-name/frp         display="Persistent"

# AVB Attestation Blocks
/vbmeta         emmc    /dev/block/platform/bootdevice/by-name/vbmeta            display="VBMeta";backup=1;flashimg=1
/vbmeta_system  emmc    /dev/block/platform/bootdevice/by-name/vbmeta_system     display="VBMeta System";backup=1
/vbmeta_vendor  emmc    /dev/block/platform/bootdevice/by-name/vbmeta_vendor     display="VBMeta Vendor";backup=1

# Under-The-Hood Platform Modules
/proinfo        emmc    /dev/block/platform/bootdevice/by-name/proinfo           display="Proinfo"
/bootloader     emmc    /dev/block/platform/bootdevice/by-name/lk                display="Bootloader (lk)"
/bootloader2    emmc    /dev/block/platform/bootdevice/by-name/lk2               display="Bootloader2 (lk2)"
/para           emmc    /dev/block/platform/bootdevice/by-name/para              display="Para"
/expdb          emmc    /dev/block/platform/bootdevice/by-name/expdb             display="Expdb"
/seccfg         emmc    /dev/block/platform/bootdevice/by-name/seccfg            display="Seccfg"
/tee1           emmc    /dev/block/platform/bootdevice/by-name/tee1              display="TEE 1"
/tee2           emmc    /dev/block/platform/bootdevice/by-name/tee2              display="TEE 2"
/scp1           emmc    /dev/block/platform/bootdevice/by-name/scp1              display="SCP 1"
/scp2           emmc    /dev/block/platform/bootdevice/by-name/scp2              display="SCP 2"
/sspm_1         emmc    /dev/block/platform/bootdevice/by-name/sspm_1            display="SSPM 1"
/sspm_2         emmc    /dev/block/platform/bootdevice/by-name/sspm_2            display="SSPM 2"
/md1img         emmc    /dev/block/platform/bootdevice/by-name/md1img            display="Modem (md1img)"
/md1dsp         emmc    /dev/block/platform/bootdevice/by-name/md1dsp            display="Modem DSP"
/gz1            emmc    /dev/block/platform/bootdevice/by-name/gz1               display="GZ 1"
/gz2            emmc    /dev/block/platform/bootdevice/by-name/gz2               display="GZ 2"
/spmfw          emmc    /dev/block/platform/bootdevice/by-name/spmfw             display="SPM FW"
/boot_para      emmc    /dev/block/platform/bootdevice/by-name/boot_para         display="Boot Para"
/otp            emmc    /dev/block/platform/bootdevice/by-name/otp               display="OTP"
